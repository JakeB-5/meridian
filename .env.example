# =============================================================================
# Meridian — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (metadata store)
# -----------------------------------------------------------------------------

# PostgreSQL connection string for the Meridian metadata database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://meridian:changeme@localhost:5432/meridian

# Individual Postgres credentials (used by docker-compose)
POSTGRES_USER=meridian
POSTGRES_PASSWORD=changeme
POSTGRES_DB=meridian

# -----------------------------------------------------------------------------
# Redis (cache + BullMQ queue backend)
# -----------------------------------------------------------------------------

# Redis connection URL
# Format: redis://[:PASSWORD@]HOST:PORT[/DB_NUMBER]
REDIS_URL=redis://localhost:6379

# Redis password (leave empty for no auth in dev)
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------

# Port the Fastify API server listens on
PORT=3001

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# JWT signing secret — generate with: openssl rand -base64 64
# REQUIRED in production. Auto-generated on first run in dev.
JWT_SECRET=

# JWT token expiry (e.g. 7d, 24h, 3600s)
JWT_EXPIRY=7d

# Allowed CORS origin(s) for the API server
# Comma-separated for multiple: http://localhost:5173,https://app.example.com
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Web App
# -----------------------------------------------------------------------------

# Port the web dev server (Vite) listens on
WEB_PORT=5173

# API base URL (accessible from the browser)
VITE_API_URL=http://localhost:3001

# WebSocket URL (accessible from the browser)
VITE_WS_URL=ws://localhost:3001

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------

# Number of concurrent BullMQ workers
WORKER_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Session secret — generate with: openssl rand -base64 64
SESSION_SECRET=

# OAuth / SSO (optional)
# OIDC_ISSUER=https://accounts.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_CALLBACK_URL=http://localhost:3001/auth/oidc/callback

# SAML (optional)
# SAML_ENTRY_POINT=
# SAML_ISSUER=
# SAML_CERT=

# -----------------------------------------------------------------------------
# Email (optional — for alerts and exports)
# -----------------------------------------------------------------------------

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Storage (optional — for exported reports/snapshots)
# -----------------------------------------------------------------------------

# Local filesystem path or S3-compatible bucket for exports
# STORAGE_TYPE=local
# STORAGE_PATH=/app/data/exports

# S3 / compatible object storage
# STORAGE_TYPE=s3
# S3_BUCKET=meridian-exports
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=         # Leave empty for AWS; set for MinIO/Cloudflare R2

# -----------------------------------------------------------------------------
# AI / NL-to-SQL (optional)
# -----------------------------------------------------------------------------

# OpenAI API key for NL-to-SQL and auto-insights
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Anthropic API key (alternative)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------

# OpenTelemetry collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=meridian-server

# Sentry DSN
# SENTRY_DSN=
